# -------------------------------------------------------
# AKS Metrics Assistant - Phase 1
# Copy this file to .env for local development only.
# NEVER commit .env to source control.
# In production, use Kubernetes Secrets.
# -------------------------------------------------------

# -------------------------------------------------------
# PROMETHEUS SOURCES
#
# JSON array — 3 sources aligned with Grafana datasources.
# Grafana is NOT queried directly. This service queries
# Prometheus-compatible endpoints via /api/v1/query.
#
# auth_type: none
#   No Authorization header.
#
# auth_type: basic
#   HTTP Basic Auth with username + password.
#
# auth_type: azure_ad  (two modes)
#   A) With tenant_id + client_id + client_secret:
#      Uses ClientSecretCredential (app registration).
#      Set directory_id -> tenant_id
#          application_id -> client_id
#          client_secret  -> client_secret
#          default_subscription -> subscription_id
#   B) Without per-source creds:
#      Uses DefaultAzureCredential:
#      Workload Identity > Managed Identity > env vars > Azure CLI
#
# DNS note:
#   http://prometheus:9090
#     Works when Metrics Service is in the SAME namespace as Prometheus.
#   http://prometheus.<namespace>.svc.cluster.local:9090
#     Use when in a DIFFERENT namespace.
# -------------------------------------------------------
PROMETHEUS_SOURCES=[
  {
    "name": "Prometheus",
    "type": "aks",
    "url": "http://prometheus:9090",
    "auth_type": "basic",
    "username": "REPLACE_USERNAME",
    "password": "REPLACE_PASSWORD",
    "description": "Dev AKS in-cluster Prometheus"
  },
  {
    "name": "uat-monitor-workspace",
    "type": "azure",
    "url": "https://management.azure.com",
    "auth_type": "azure_ad",
    "tenant_id": "REPLACE_DIRECTORY_ID",
    "client_id": "REPLACE_APPLICATION_ID",
    "client_secret": "REPLACE_CLIENT_SECRET",
    "subscription_id": "REPLACE_DEFAULT_SUBSCRIPTION_ID",
    "description": "Azure Monitor workspace (app registration auth)"
  },
  {
    "name": "uat-monitor-workspace-prometheus",
    "type": "azure",
    "url": "https://uat-monitor-workspace-z91u.canadacentral.prometheus.monitor.azure.com",
    "auth_type": "azure_ad",
    "tenant_id": "REPLACE_DIRECTORY_ID",
    "client_id": "REPLACE_APPLICATION_ID",
    "client_secret": "REPLACE_CLIENT_SECRET",
    "subscription_id": "REPLACE_DEFAULT_SUBSCRIPTION_ID",
    "description": "Azure Monitor Managed Prometheus (Prometheus-compatible endpoint)"
  }
]

# -------------------------------------------------------
# Prometheus query settings
# -------------------------------------------------------
PROMETHEUS_TIMEOUT_SECONDS=10
PROMETHEUS_MAX_RESULTS=100
PROMETHEUS_DEFAULT_RANGE=24h
ALLOWED_RANGES=1h,6h,12h,24h,2d,7d

# -------------------------------------------------------
# Daily report scope
#
# Keep this explicit to avoid sending unnecessary datasource
# results to Claude.
#
# Include only Prometheus-compatible sources that should appear
# in the daily report. Do not include the Azure Monitor workspace
# source unless it exposes a Prometheus-compatible query API.
# -------------------------------------------------------
DAILY_REPORT_SOURCES=Prometheus,uat-monitor-workspace-prometheus
DAILY_REPORT_NAMESPACES=default,kube-system,monitoring

# -------------------------------------------------------
# A