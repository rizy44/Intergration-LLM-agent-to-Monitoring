# -------------------------------------------------------
# AKS Metrics Assistant - Phase 1
# Copy this file to .env for local development only.
# NEVER commit .env to source control.
# In production, use Kubernetes Secrets.
# -------------------------------------------------------

# -------------------------------------------------------
# PROMETHEUS SOURCES
# App reads these individual variables when PROMETHEUS_SOURCES is empty.
# Use PROMETHEUS_SOURCES only if you need a custom JSON source list.
# -------------------------------------------------------
PROMETHEUS_SOURCES=

# Local / in-cluster Prometheus
PROMETHEUS_AKS_NAME=Prometheus
PROMETHEUS_AKS_URL=http://prometheus:9090
PROMETHEUS_AKS_AUTH_TYPE=basic
PROMETHEUS_AKS_USERNAME=REPLACE_USERNAME
PROMETHEUS_AKS_PASSWORD=REPLACE_PASSWORD
PROMETHEUS_AKS_DESCRIPTION=In-cluster Prometheus

# Azure Monitor Managed Prometheus
PROMETHEUS_AZURE_NAME=uat-monitor-workspace-prometheus
PROMETHEUS_AZURE_URL=https://REPLACE_WORKSPACE_NAME.canadacentral.prometheus.monitor.azure.com
PROMETHEUS_AZURE_AUTH_TYPE=azure_ad
PROMETHEUS_AZURE_TENANT_ID=REPLACE_DIRECTORY_ID
PROMETHEUS_AZURE_CLIENT_ID=REPLACE_APPLICATION_ID
PROMETHEUS_AZURE_CLIENT_SECRET=REPLACE_CLIENT_SECRET_VALUE
PROMETHEUS_AZURE_SUBSCRIPTION_ID=REPLACE_SUBSCRIPTION_ID
PROMETHEUS_AZURE_DESCRIPTION=Azure Monitor Managed Prometheus

# -------------------------------------------------------
# Prometheus query settings
# -------------------------------------------------------
PROMETHEUS_TIMEOUT_SECONDS=10
PROMETHEUS_MAX_RESULTS=100
PROMETHEUS_DEFAULT_RANGE=24h
ALLOWED_RANGES=1h,6h,12h,24h,2d,7d

# -------------------------------------------------------
# Daily report scope
#
# DAILY_REPORT_SOURCES: comma-separated source names to include.
#   Use only Prometheus-compatible sources (type: aks or azure).
# DAILY_REPORT_NAMESPACES: comma-separated namespaces to monitor.
# -------------------------------------------------------
DAILY_REPORT_SOURCES=Prometheus,uat-monitor-workspace-prometheus
DAILY_REPORT_NAMESPACES=default,kube-system,monitoring

# -------------------------------------------------------
# Anthropic
# -------------------------------------------------------
ANTHROPIC_API_KEY=REPLACE_ANTHROPIC_API_KEY
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=1024

# -------------------------------------------------------
# Microsoft Teams
# -------------------------------------------------------
TEAMS_WEBHOOK_URL=REPLACE_TEAMS_INCOMING_WEBHOOK_URL
TEAMS_OUTGOING_WEBHOOK_SECRET=REPLACE_TEAMS_OUTGOING_WEBHOOK_SECRET
